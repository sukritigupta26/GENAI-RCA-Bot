# LLM (xAI Grok recommended)
LLM_PROVIDER=xai          # or openai
XAI_API_KEY=your_xai_key_here
OPENAI_API_KEY=sk-...     # fallback

# Kubernetes (in-cluster recommended for production)
K8S_IN_CLUSTER=true

# Jenkins
JENKINS_URL=http://jenkins:8080
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=your-token

# Ansible Tower / AWX
ANSIBLE_TOWER_URL=https://tower.yourcompany.com
ANSIBLE_TOWER_USERNAME=admin
ANSIBLE_TOWER_PASSWORD=your-password

# Slack / Teams notification (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...